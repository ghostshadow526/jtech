# SMM API Key (smexploits)
SMM_API_KEY=your_api_key_here

# Paystack Configuration (Live Keys)
# IMPORTANT: Add your real keys only in Vercel Environment Variables, NOT here!
# Never commit real secret keys to git
# Get your keys from: https://dashboard.paystack.com/settings/developer
VITE_PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# Domain Configuration (for Vercel)
DOMAIN=https://jcreativetechnologies.com

# Firebase Admin Credentials (optional if using default service account in Cloud Run)
# FIREBASE_SERVICE_ACCOUNT=